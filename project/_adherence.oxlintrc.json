{
  "plugins": [
    "react",
    "import"
  ],
  "rules": {
    "react/forbid-elements": [
      "warn",
      {
        "forbid": []
      }
    ],
    "no-restricted-imports": [
      "warn",
      {
        "patterns": [
          {
            "group": [
              "components/core/**",
              "components/data/**",
              "ui_kits/augur/**"
            ],
            "message": "Import design-system components from 'index.js', not component internals."
          }
        ]
      }
    ],
    "no-restricted-syntax": [
      "warn",
      {
        "selector": "Literal[value=/#[0-9a-fA-F]{3,8}\\b/]",
        "message": "Raw hex color — use a design-system color token via var()."
      },
      {
        "selector": "Literal[value=/\\b\\d+px\\b/]",
        "message": "Raw px value — use a design-system spacing token via var()."
      },
      {
        "selector": "Literal[value=/font-family\\s*:\\s*(?!['\\\"]?(?:IBM Plex Mono|IBM Plex Sans Condensed|IBM Plex Sans))/i]",
        "message": "Font not provided by the design system. Available: IBM Plex Mono, IBM Plex Sans Condensed, IBM Plex Sans."
      },
      {
        "selector": "JSXOpeningElement[name.name='Badge'] > JSXAttribute > JSXIdentifier[name!=/^(?:children|tone|solid|icon|style|key|ref|className|style|children)$/]",
        "message": "<Badge> doesn't accept that prop. Declared props: children, tone, solid, icon, style."
      },
      {
        "selector": "JSXOpeningElement[name.name='Badge'] > JSXAttribute[name.name='tone'] > Literal[value!=/^(?:neutral|signal|win|caution|flee)$/]",
        "message": "<Badge> tone must be one of 'neutral' | 'signal' | 'win' | 'caution' | 'flee'."
      },
      {
        "selector": "JSXOpeningElement[name.name='Button'] > JSXAttribute > JSXIdentifier[name!=/^(?:variant|size|icon|block|disabled|children|key|ref|className|style|children)$/]",
        "message": "<Button> doesn't accept that prop. Declared props: variant, size, icon, block, disabled, children."
      },
      {
        "selector": "JSXOpeningElement[name.name='Button'] > JSXAttribute[name.name='variant'] > Literal[value!=/^(?:primary|secondary|ghost|danger)$/]",
        "message": "<Button> variant must be one of 'primary' | 'secondary' | 'ghost' | 'danger'."
      },
      {
        "selector": "JSXOpeningElement[name.name='Button'] > JSXAttribute[name.name='size'] > Literal[value!=/^(?:md|lg)$/]",
        "message": "<Button> size must be one of 'md' | 'lg'."
      },
      {
        "selector": "JSXOpeningElement[name.name='Card'] > JSXAttribute > JSXIdentifier[name!=/^(?:elevation|padding|selected|glow|children|key|ref|className|style|children)$/]",
        "message": "<Card> doesn't accept that prop. Declared props: elevation, padding, selected, glow, children."
      },
      {
        "selector": "JSXOpeningElement[name.name='IconButton'] > JSXAttribute > JSXIdentifier[name!=/^(?:variant|size|children|key|ref|className|style|children)$/]",
        "message": "<IconButton> doesn't accept that prop. Declared props: variant, size, children."
      },
      {
        "selector": "JSXOpeningElement[name.name='IconButton'] > JSXAttribute[name.name='variant'] > Literal[value!=/^(?:secondary|ghost|signal)$/]",
        "message": "<IconButton> variant must be one of 'secondary' | 'ghost' | 'signal'."
      },
      {
        "selector": "JSXOpeningElement[name.name='IconButton'] > JSXAttribute[name.name='size'] > Literal[value!=/^(?:md|lg)$/]",
        "message": "<IconButton> size must be one of 'md' | 'lg'."
      },
      {
        "selector": "JSXOpeningElement[name.name='OutcomeDistribution'] > JSXAttribute > JSXIdentifier[name!=/^(?:win|draw|give|fallback|flee|key|ref|className|style|children)$/]",
        "message": "<OutcomeDistribution> doesn't accept that prop. Declared props: win, draw, give, fallback, flee."
      },
      {
        "selector": "JSXOpeningElement[name.name='OutcomeLegend'] > JSXAttribute > JSXIdentifier[name!=/^(?:dist|columns|highlightFlee|style|key|ref|className|style|children)$/]",
        "message": "<OutcomeLegend> doesn't accept that prop. Declared props: dist, columns, highlightFlee, style."
      },
      {
        "selector": "JSXOpeningElement[name.name='SegmentedOption'] > JSXAttribute > JSXIdentifier[name!=/^(?:value|label|key|ref|className|style|children)$/]",
        "message": "<SegmentedOption> doesn't accept that prop. Declared props: value, label."
      },
      {
        "selector": "JSXOpeningElement[name.name='StatPill'] > JSXAttribute > JSXIdentifier[name!=/^(?:label|value|emphasis|style|key|ref|className|style|children)$/]",
        "message": "<StatPill> doesn't accept that prop. Declared props: label, value, emphasis, style."
      },
      {
        "selector": "JSXOpeningElement[name.name='StatusDot'] > JSXAttribute > JSXIdentifier[name!=/^(?:status|showLabel|pulse|style|key|ref|className|style|children)$/]",
        "message": "<StatusDot> doesn't accept that prop. Declared props: status, showLabel, pulse, style."
      },
      {
        "selector": "JSXOpeningElement[name.name='StatusDot'] > JSXAttribute[name.name='status'] > Literal[value!=/^(?:full|weak|fleeing|destroyed)$/]",
        "message": "<StatusDot> status must be one of 'full' | 'weak' | 'fleeing' | 'destroyed'."
      },
      {
        "selector": "JSXOpeningElement[name.name='Stepper'] > JSXAttribute > JSXIdentifier[name!=/^(?:value|onChange|min|max|step|label|signed|size|style|key|ref|className|style|children)$/]",
        "message": "<Stepper> doesn't accept that prop. Declared props: value, onChange, min, max, step, label, signed, size, style."
      },
      {
        "selector": "JSXOpeningElement[name.name='Stepper'] > JSXAttribute[name.name='size'] > Literal[value!=/^(?:md|lg)$/]",
        "message": "<Stepper> size must be one of 'md' | 'lg'."
      },
      {
        "selector": "JSXOpeningElement[name.name='Switch'] > JSXAttribute > JSXIdentifier[name!=/^(?:checked|onChange|label|disabled|style|key|ref|className|style|children)$/]",
        "message": "<Switch> doesn't accept that prop. Declared props: checked, onChange, label, disabled, style."
      },
      {
        "selector": "JSXOpeningElement[name.name='UnitProfile'] > JSXAttribute > JSXIdentifier[name!=/^(?:cc|str|tou|att|save|cd|key|ref|className|style|children)$/]",
        "message": "<UnitProfile> doesn't accept that prop. Declared props: cc, str, tou, att, save, cd."
      },
      {
        "selector": "JSXOpeningElement[name.name='VPMeter'] > JSXAttribute > JSXIdentifier[name!=/^(?:value|range|size|style|key|ref|className|style|children)$/]",
        "message": "<VPMeter> doesn't accept that prop. Declared props: value, range, size, style."
      },
      {
        "selector": "JSXOpeningElement[name.name='VPMeter'] > JSXAttribute[name.name='size'] > Literal[value!=/^(?:hero|compact)$/]",
        "message": "<VPMeter> size must be one of 'hero' | 'compact'."
      }
    ]
  },
  "overrides": [
    {
      "files": [
        "**/index.js"
      ],
      "rules": {
        "no-restricted-imports": "off"
      }
    }
